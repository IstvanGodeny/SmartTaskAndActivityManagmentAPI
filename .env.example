# Copy this file to .env and replace placeholder values

APP_NAME="Smart Task Manager"
ENV="local"

DATABASE_URL="postgresql+psycopg://your_username:your_password@localhost:5432/stm_db"

#--- Auth / JWT ---
# Example:
# SECRET_KEY=$(openssl rand -hex 32)
SECRET_KEY="change_me_to_a_secure_random_string"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
